{% block article_header %}
{% include "article-header.njk" %}
            <script>
                (function() {
                    var hero = document.querySelector('.post-hero');
                    if (!hero) return;
                    var h = hero.offsetHeight;
                    window.addEventListener('scroll', function() {
                        var t = Math.min(window.scrollY / (h * 0.8), 1);
                        hero.style.opacity = 1 - t;
                    }, { passive: true });
                })();
            </script>
