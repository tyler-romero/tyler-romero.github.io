<!DOCTYPE html>
<html lang="en">
    <head>
        {% include "head.njk" %}
        {% block structured_data %}{% endblock %}
    </head>
    <body>
        <header>
            <nav class="topbar">
                <div class="right-aligned-links">
                    <a href="/"
                       class="no-tufte-underline nav-brand">Tyler Romero</a>
                    {% block nav_links %}
                    <a href="/#posts" class="no-tufte-underline">posts</a>
                    <span class="desktop-only">
                        <a href="/#projects" class="no-tufte-underline">projects</a>
                        <a href="/#reading-list" class="no-tufte-underline">reading list</a>
                    </span>
                    {% endblock %}
                </div>
            </nav>
        </header>
        <article>
            {% block article_header %}{% endblock %}
            {{ content | safe }}
        </article>
        <footer>
            {% include "footer.njk" %}
        </footer>
        <script>
            (function() {
                var header = document.querySelector('header');
                var lastY = window.scrollY;
                var offset = 0;
                var headerH = header.offsetHeight;
                window.addEventListener('scroll', function() {
                    var y = window.scrollY;
                    var delta = y - lastY;
                    offset = Math.min(0, Math.max(-headerH, offset - delta));
                    if (y <= 0) offset = 0;
                    header.style.transform = 'translateY(' + offset + 'px)';
                    lastY = y;
                }, { passive: true });
            })();
        </script>
    </body>
</html>
